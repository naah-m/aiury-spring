        {
          "name": "Criar estado",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nomeEstado\": \"Sao Paulo\",\n  \"uf\": \"SP\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/estados",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "estados"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', function () { pm.response.to.have.status(201); });",
                  "const json = pm.response.json();",
                  "if (json.id) { pm.environment.set('estadoId', json.id); }"
