      "item": [
        {
          "name": "Criar usuario",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nomeReal\": \"Maria Silva\",\n  \"nomeAnonimo\": \"LuzInterior\",\n  \"dataNascimento\": \"15-08-1998\",\n  \"celular\": \"11999998888\",\n  \"senha\": \"segredo123\",\n  \"cidadeId\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/usuarios",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "usuarios"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  if (json.id) { pm.environment.set('usuarioId', json.id); }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
